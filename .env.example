# Mingdao Open API (应用开发 → API 文档)
MINGDAO_APP_KEY=
MINGDAO_SIGN=
MINGDAO_API_BASE=https://api.mingdao.com/v2/open/worksheet

# 五站 GSC URL + Ahrefs 域名 → config/sites.json
# 看板单选 key → config/mingdao_options.json
# 关键词/页面/外链表 → config/mingdao_worksheets.json
# 关键词表可选列（有列则填 controlId，sync 每次覆盖写入）
# MINGDAO_FIELD_KEYWORD_CPC=
# MINGDAO_FIELD_KEYWORD_VALUE_SCORE=
# 可选：SYNC_SITES=cncpioneer,fecision

# SEO 自动数据看板
MINGDAO_WORKSHEET_DASHBOARD=
MINGDAO_FIELD_DASH_DATE=
MINGDAO_FIELD_DASH_SITE=
MINGDAO_FIELD_DASH_CLICKS=
MINGDAO_FIELD_DASH_IMPRESSIONS=
MINGDAO_FIELD_DASH_CTR=
MINGDAO_FIELD_DASH_POSITION=
# 排名分档（Ahrefs 有机词，默认 US）
MINGDAO_FIELD_DASH_TOP1_3=
MINGDAO_FIELD_DASH_TOP4_10=
MINGDAO_FIELD_DASH_TOP11_20=
MINGDAO_FIELD_DASH_TOP21_100=
MINGDAO_FIELD_DASH_BACKLINKS=
MINGDAO_FIELD_DASH_WEEKLY_AVG_POSITION=
MINGDAO_FIELD_DASH_WEEKLY_CLICKS=
# MINGDAO_FIELD_DASH_SITE_DR=
MINGDAO_FIELD_DASH_INDEXED=
MINGDAO_FIELD_DASH_ISSUES=
MINGDAO_FIELD_DASH_ALERT=
MINGDAO_FIELD_DASH_TRAFFIC_WOW=
# 各档周环比（锚点日 vs 锚点-7 天，分母为 0 则不写入）
MINGDAO_FIELD_DASH_TOP1_3_WOW=
MINGDAO_FIELD_DASH_TOP4_10_WOW=
MINGDAO_FIELD_DASH_TOP11_20_WOW=
MINGDAO_FIELD_DASH_TOP21_100_WOW=

# GSC Top 明细（建表后填 worksheetId + controlId，见 docs/dashboard.md §4.7–4.8）
# MINGDAO_WORKSHEET_GSC_TOP_QUERIES=
# MINGDAO_WORKSHEET_GSC_TOP_PAGES=
# MINGDAO_FIELD_GSC_QUERY_DATA_DATE=
# MINGDAO_FIELD_GSC_QUERY_SITE=
# MINGDAO_FIELD_GSC_QUERY_KEYWORD=
# MINGDAO_FIELD_GSC_QUERY_COUNTRY=
# MINGDAO_FIELD_GSC_QUERY_CLICKS=
# MINGDAO_FIELD_GSC_QUERY_IMPRESSIONS=
# MINGDAO_FIELD_GSC_QUERY_CTR=
# MINGDAO_FIELD_GSC_QUERY_POSITION=
# MINGDAO_FIELD_GSC_PAGE_DATA_DATE=
# MINGDAO_FIELD_GSC_PAGE_SITE=
# MINGDAO_FIELD_GSC_PAGE_URL=
# MINGDAO_FIELD_GSC_PAGE_COUNTRY=
# MINGDAO_FIELD_GSC_PAGE_CLICKS=
# MINGDAO_FIELD_GSC_PAGE_IMPRESSIONS=
# MINGDAO_FIELD_GSC_PAGE_CTR=
# MINGDAO_FIELD_GSC_PAGE_POSITION=
# GSC_TOP_QUERIES_LIMIT=1000
# GSC_TOP_PAGES_LIMIT=1000

# Google Search Console
GOOGLE_AUTH_MODE=oauth
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
GOOGLE_TOKEN_FILE=token.json

# Ahrefs
AHREFS_API_TOKEN=
# 单国：us / gb / de …  全球汇总：all（见下方 AGGREGATE 配置）
AHREFS_TARGET_COUNTRY=us
# 当 TARGET_COUNTRY=all 时生效：
# 1) 手动指定国家（推荐，API 次数 = 国家数 × 站点数）
# AHREFS_AGGREGATE_COUNTRIES=us,gb,de,au,ca,in,jp,kr,tw
# 2) 留空则自动拉 metrics-by-country 中有排名的全部国家（可能 50+ 次/站）
AHREFS_AGGREGATE_COUNTRIES=
# 自动发现时最多取几个国家（按自然流量排序）；0 = 不限制
AHREFS_AGGREGATE_MAX_COUNTRIES=0
# 外链表每次导入条数（每站）
AHREFS_BACKLINKS_LIMIT=500

DATA_DELAY_DAYS=3
# 覆盖锚点日（与 run_sync.bat 同传）：python script/sync.py --anchor-date 2026-05-30 --site richconn ...
DASHBOARD_SYNC_DAYS=7
CACHE_ENABLED=1
CACHE_TTL_HOURS=12
GSC_RECENT_REFRESH_DAYS=2

# Google GSC：GOOGLE_PROXY 留空 → 使用 Clash 系统代理（全局/智能，无需 TUN）
GOOGLE_PROXY=
