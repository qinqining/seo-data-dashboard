# Mingdao Open API（应用开发 → API 文档；密钥勿提交 git）
MINGDAO_APP_KEY=
MINGDAO_SIGN=
MINGDAO_API_BASE=https://api.mingdao.com/v2/open/worksheet
MINGDAO_REQUEST_TIMEOUT=180
# 五站配置见 config/sites.json（GSC URL + Ahrefs 域名）
# 看板「独立站」单选 key 见 config/mingdao_options.json
# 关键词/页面表字段 ID 见 config/mingdao_worksheets.json
# 可选：只跑部分站，逗号分隔；drametal 服务器/GSC 暂跳过时可排除
SYNC_SITES=cncpioneer,fecision,richconn,lasermicrofab

# SEO 自动数据看板
MINGDAO_WORKSHEET_DASHBOARD=6a1d1d1914420b8440cd6adf
MINGDAO_FIELD_DASH_DATE=6a27c960d81f90f0982b3567
MINGDAO_FIELD_DASH_SITE=6a1d26ece33c925fdd2ac216
MINGDAO_FIELD_DASH_CLICKS=6a1d22c2e30907a70fa427d5
MINGDAO_FIELD_DASH_IMPRESSIONS=6a1d22c2e30907a70fa427d6
MINGDAO_FIELD_DASH_CTR=6a1d22c2e30907a70fa427d7
MINGDAO_FIELD_DASH_POSITION=6a1d22c2e30907a70fa427d8
# 旧列名（若明道云仍保留可填；新四档见下方 TOP1_3 等）
MINGDAO_FIELD_DASH_TOP10=6a1d22c2e30907a70fa427d9
MINGDAO_FIELD_DASH_TOP30=6a1d22c2e30907a70fa427da
MINGDAO_FIELD_DASH_BACKLINKS=6a1d22c2e30907a70fa427db
MINGDAO_FIELD_DASH_INDEXED=6a1d22c2e30907a70fa427dc
MINGDAO_FIELD_DASH_ISSUES=6a1d22c2e30907a70fa427dd
MINGDAO_FIELD_DASH_ALERT=6a1d22c2e30907a70fa427de
MINGDAO_FIELD_DASH_TRAFFIC_WOW=6a1d22c2e30907a70fa427df
MINGDAO_FIELD_DASH_TOP30_WOW=6a1d22c2e30907a70fa427e0

# 站点关键词库（可选列，controlId 覆盖 config/mingdao_worksheets.json）
MINGDAO_FIELD_KEYWORD_SITE=6a27eb090e52596f861cd7fd
MINGDAO_FIELD_KEYWORD_CPC=6a1f8db39d097b38ad817c0c
MINGDAO_FIELD_KEYWORD_VALUE_SCORE=6a1f926caa351318ffd2c7fa
MINGDAO_FIELD_DASH_WEEKLY_AVG_POSITION=6a1fdbfe340b8eb11013526c

# Google Search Console（OAuth；凭证文件勿提交 git，五站 URL 在 config/sites.json）
GOOGLE_AUTH_MODE=oauth
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
GOOGLE_TOKEN_FILE=token.json

# Ahrefs（Token 勿提交 git；各站域名在 config/sites.json）
# AHREFS_API_TOKEN=
AHREFS_TARGET_COUNTRY=all
# AHREFS_AGGREGATE_COUNTRIES=us,gb,de,au,ca,in,jp,kr,tw,pl
# AHREFS_AGGREGATE_MAX_COUNTRIES=0

DATA_DELAY_DAYS=3
# 看板回填天数（锚点日往前共 N 天，一天一行）
DASHBOARD_SYNC_DAYS=7
# GSC 本地缓存（cache/gsc/）；近期仍为 0 的日期会自动重拉
CACHE_ENABLED=1
CACHE_TTL_HOURS=12
GSC_RECENT_REFRESH_DAYS=2

# Google：留空 = 走 Clash 系统代理（全局/智能均可）
GOOGLE_PROXY=

# 看板 GSC 四档搜索词数（列名 GSC Top1-3 … Top21-100）
MINGDAO_FIELD_DASH_TOP1_3=6a1d22c2e30907a70fa427d9
MINGDAO_FIELD_DASH_TOP4_10=6a1d22c2e30907a70fa427da
MINGDAO_FIELD_DASH_TOP11_20=6a1e91592365c8d0c2a91e33
MINGDAO_FIELD_DASH_TOP21_100=6a1e91592365c8d0c2a91e34
# 看板可选列：本站 Ahrefs DR（锚点日一行）
MINGDAO_FIELD_DASH_SITE_DR=6a21370d52679745c356e230

# 页面表 Ahrefs import
PAGES_AHREFS_IMPORT_LIMIT=1000
PAGES_AHREFS_IMPORT_MIN_TRAFFIC=0

# GSC Top 查询明细（字段 ID 默认见 config/mingdao_worksheets.json，此处可覆盖）
MINGDAO_WORKSHEET_GSC_TOP_QUERIES=6a20d783020978ab1599da85
MINGDAO_FIELD_GSC_QUERY_DATA_DATE=6a20dc182365c8d0c2ab20f9
# 勿随意改独立站 controlId；须与表内已有数据列一致（默认 6a20dc182365c8d0c2ab20fa，见 mingdao_worksheets.json）
# MINGDAO_FIELD_GSC_QUERY_SITE=6a20dc182365c8d0c2ab20fa
MINGDAO_FIELD_GSC_QUERY_KEYWORD=6a20dc182365c8d0c2ab20fb
MINGDAO_FIELD_GSC_QUERY_COUNTRY=6a20dc182365c8d0c2ab20fc
MINGDAO_FIELD_GSC_QUERY_CLICKS=6a20dc182365c8d0c2ab20fd
MINGDAO_FIELD_GSC_QUERY_IMPRESSIONS=6a20dc182365c8d0c2ab20fe
MINGDAO_FIELD_GSC_QUERY_CTR=6a20dc182365c8d0c2ab20ff
MINGDAO_FIELD_GSC_QUERY_POSITION=6a20dc182365c8d0c2ab2100
MINGDAO_FIELD_GSC_QUERY_AHREFS_VOLUME=6a266c773a3063763d668fa9
MINGDAO_FIELD_GSC_QUERY_AHREFS_KD=6a266c773a3063763d668faa
MINGDAO_FIELD_GSC_QUERY_AHREFS_CPC=6a266c773a3063763d668fab

# GSC Top 页面明细
MINGDAO_WORKSHEET_GSC_TOP_PAGES=6a20dc8c9376fc2a09ebda68
MINGDAO_FIELD_GSC_PAGE_DATA_DATE=6a20dfc3e30907a70fa73485
# MINGDAO_FIELD_GSC_PAGE_SITE=6a20dfc3e30907a70fa73486
MINGDAO_FIELD_GSC_PAGE_COUNTRY=6a20dfc3e30907a70fa73487
MINGDAO_FIELD_GSC_PAGE_URL=6a20dfc3e30907a70fa73488
MINGDAO_FIELD_GSC_PAGE_CLICKS=6a20dfc3e30907a70fa73489
MINGDAO_FIELD_GSC_PAGE_IMPRESSIONS=6a20dfc3e30907a70fa7348a
MINGDAO_FIELD_GSC_PAGE_CTR=6a20dfc3e30907a70fa7348b
MINGDAO_FIELD_GSC_PAGE_POSITION=6a20dfc3e30907a70fa7348c

GSC_TOP_QUERIES_LIMIT=1000
GSC_TOP_PAGES_LIMIT=1000
# GSC Top 查询 Ahrefs enrich（GSC sync 后自动执行；留空国家 = 全部国家）
GSC_TOP_QUERIES_ENRICH_COUNTRIES=
GSC_TOP_QUERIES_ENRICH_MODE=clicks_gt_zero
GSC_TOP_QUERIES_ENRICH_LIMIT=500
# DASHBOARD_GSC_QUERY_LIMIT=1000

# 页面管理表（MINGDAO_FIELD_PAGE_* 覆盖 config/mingdao_worksheets.json）
MINGDAO_WORKSHEET_PAGES=6a1d1e60113e1b2e9c6f5e56
